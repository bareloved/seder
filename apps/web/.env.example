# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Better Auth
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=             # Generate with: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3001

# Google OAuth (Calendar integration)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com  # iOS app Google Sign-In

# Gemini API (AI features)
GEMINI_API_KEY=your-gemini-api-key

# Resend (transactional emails)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@mail.yourdomain.com
FEEDBACK_EMAIL=feedback@yourdomain.com

# Push notifications cron (used by /api/v1/cron endpoint)
CRON_SECRET=your-cron-secret

# Apple Push Notifications (APNs)
APNS_KEY_ID=your-key-id               # From Apple Developer portal (Keys section)
APNS_TEAM_ID=your-team-id             # Apple Developer Team ID
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"  # Contents of .p8 file (use \n for newlines)
APNS_ENVIRONMENT=production            # "development" for sandbox, "production" for TestFlight/App Store

# Sentry
NEXT_PUBLIC_SENTRY_DSN=xxx
SENTRY_ORG=xxx
SENTRY_PROJECT=xxx
SENTRY_AUTH_TOKEN=xxx

# Upstash (Rate Limiting)
UPSTASH_REDIS_REST_URL=xxx
UPSTASH_REDIS_REST_TOKEN=xxx

# DB Backups (Neon)
NEON_PROJECT_ID=xxx
NEON_API_KEY=xxx

# Admin dashboard allowlist (comma-separated emails)
ADMIN_EMAILS=you@example.com

# Service Token (external app API access)
SEDER_API_TOKEN=              # Generate with: openssl rand -hex 32
SEDER_API_USER_ID=            # Your user ID from the database
